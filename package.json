{
  "name": "interviewai-netlify",
  "version": "1.0.0",
  "description": "InterviewAI - AI Mock Interview Platform for Netlify",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:frontend && npm run build:functions",
    "build:frontend": "cd frontend && npm run build",
    "build:functions": "netlify-lambda build functions",
    "serve": "netlify dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:functions\"",
    "dev:frontend": "cd frontend && npm start",
    "dev:functions": "netlify-lambda serve functions"
  },
  "dependencies": {
    "netlify-lambda": "^2.0.16",
    "serverless-http": "^3.0.2",
    "flask": "^2.3.3",
    "werkzeug": "^2.3.7",
    "python-dotenv": "^1.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "netlify-cli": "^17.21.0"
  },
  "keywords": [
    "interview",
    "ai",
    "mock",
    "practice",
    "netlify"
  ],
  "author": "InterviewAI Team",
  "license": "MIT"
}
